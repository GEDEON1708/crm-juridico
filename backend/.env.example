# Database
DATABASE_URL="postgresql://user:password@localhost:5432/crm_juridico?schema=public"

# JWT
JWT_SECRET="seu_secret_super_seguro_aqui_mude_em_producao"
JWT_REFRESH_SECRET="seu_refresh_secret_super_seguro_aqui"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# CORS
CORS_ORIGIN="http://localhost:3000"

# Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# 2FA
TWO_FACTOR_APP_NAME="CRM Juridico"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
